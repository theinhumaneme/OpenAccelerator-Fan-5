# Copy to .env and fill in values before running docker compose.

# Required: HuggingFace token for gated models (Gemma requires accepting the license).
HF_TOKEN=hf_...

# Verifier model to load in vLLM.
VERIFIER_MODEL=google/gemma-2-27b-it

# Draft model for speculative decoding.
DRAFT_MODEL=google/gemma-2-2b-it

# Which experiment config key to run (must match a key in configs/experiments.yaml).
EXPERIMENT=dense_same_family

# Number of speculative tokens proposed per step.
NUM_SPEC_TOKENS=5

# Tensor parallel size — set to the number of GPUs available.
TP_SIZE=4

# Seconds to wait for vLLM to become healthy before starting the benchmark.
VLLM_WAIT=300
