# Copy to .env and fill in values before running compose mode.

# Required for gated models. Accept the model licenses on Hugging Face first.
HF_TOKEN=hf_...

# Optional runner settings.
CONFIG=configs/experiment.yaml
VLLM_WAIT=600

# run.sh emits these from configs/experiment.yaml for the selected run_id.
# Set them manually only if you run docker compose without run.sh.
RUN_ID=run_0000_baseline_dense-31b_humaneval
VERIFIER_MODEL=google/gemma-4-31B-it
VERIFIER_DTYPE=bfloat16
SERVED_MODEL_NAME=benchmark-model
SPECULATIVE_CONFIG=
VLLM_PORT=8000
GPU_MEMORY_UTILIZATION=0.90
MAX_MODEL_LEN=4096
MAX_NUM_SEQS=1
BLOCK_SIZE=16
